class Solution {
public:
    const int MOD = 1e9 + 7;
    vector<vector<int>> hatToPeople;
    vector<vector<int>> dp;
    int n;

    int solve(int hatNo, int mask) {
        if(mask == (1 << n) - 1) return 1;  
        if(hatNo > 40) return 0;        
        if(dp[hatNo][mask] != -1) return dp[hatNo][mask];
        long long ways = 0;
        ways = solve(hatNo + 1, mask);
        for(int person : hatToPeople[hatNo]) {
            if((mask & (1 << person)) == 0) {
                ways += solve(hatNo + 1, mask | (1 << person));
                ways %= MOD;
            }
        }
        
        return dp[hatNo][mask] = ways;
    }

    int numberWays(vector<vector<int>>& hats) {
        n = hats.size();
        hatToPeople.resize(41);
        for(int person = 0; person < n; person++) {
            for(int hat : hats[person]) {
                hatToPeople[hat].push_back(person);
            }
        }
        dp.assign(41, vector<int>(1 << n, -1));
        return solve(1, 0);
    }
};
