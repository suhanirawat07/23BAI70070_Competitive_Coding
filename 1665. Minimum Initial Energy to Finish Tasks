class Solution {
public:
    int minimumEffort(vector<vector<int>>& tasks) {
        sort(tasks.begin(), tasks.end(), [](vector<int> a, vector<int> b){
            return (a[1] - a[0]) > (b[1] - b[0]);
        });
        int energy = 0, res = 0;
        for(auto task : tasks){
            int req = task[0], upper = task[1];
            if(energy < upper){
                res += upper - energy;
                energy = upper;
            }
            energy -= req;
        }
        return res;
    }
};
